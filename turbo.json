{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["TURBO_TOKEN", "TURBO_TEAM", "CI"],
  "globalDependencies": [
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "package.json",
    ".npmrc",
    "tsconfig.base.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_API_BASE_URL", "NODE_ENV"],
      "inputs": [
        "src/**",
        "index.html",
        "public/**",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig*.json",
        "tailwind.config.js",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "build:analyze": {
      "dependsOn": ["^build"],
      "env": ["ANALYZE", "VITE_API_BASE_URL", "NODE_ENV"],
      "inputs": [
        "src/**",
        "vite.config.ts",
        "package.json"
      ],
      "outputs": ["dist/**", "stats.html"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "src/**",
        "eslint.config.js",
        "*.config.{js,ts,mjs,cjs}",
        "tsconfig.json",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "typecheck": {
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig*.json",
        "package.json",
        "src/**/*.d.ts"
      ],
      "outputs": []
    },
    "test:unit": {
      "inputs": [
        "src/**",
        "__mocks__/**",
        "src/test-setup.ts",
        "vitest.setup.ts",
        "vitest.config.ts",
        "vitest.workspace.ts",
        "tsconfig.json",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    },
    "test": {
      "dependsOn": ["test:unit"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "env": ["PLAYWRIGHT_MODE", "BASE_URL", "PLAYWRIGHT_BASE_URL"],
      "inputs": [
        "tests/**",
        "playwright.config.ts",
        "tsconfig.json"
      ],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:coverage": {
      "dependsOn": [],
      "env": ["NODE_OPTIONS"],
      "inputs": [
        "src/**",
        "__mocks__/**",
        "src/test-setup.ts",
        "vitest.setup.ts",
        "vitest.config.ts",
        "vitest.workspace.ts",
        "tsconfig.json",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    }
  }
}
