{
  "name": "do-epub-studio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint && pnpm lint:workflows",
    "lint:workflows": "bash scripts/validate-workflows.sh",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:coverage": "turbo run test:unit -- --coverage",
    "test:e2e": "playwright test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e:smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "check:agent-sync": "node scripts/check-agent-sync.mjs",
    "db:migrate:local": "node scripts/db-migrate-local.mjs",
    "db:migrate:prod": "node scripts/db-migrate-prod.mjs",
    "db:check": "node scripts/db-check.mjs",
    "verify:fast": "pnpm lint && pnpm typecheck && vitest run --changed main",
    "test:e2e:smoke": "PLAYWRIGHT_MODE=dev playwright test --grep @smoke",
    "bench": "pnpm --filter @do-epub-studio/reader-core bench",
    "build:analyze": "ANALYZE=true turbo run build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25",
    "@vitest/coverage-istanbul": "4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "4.1.7",
    "wrangler": "^4.95.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.0",
      "esbuild": ">=0.28.1",
      "ws": ">=8.21.0",
      "undici": ">=7.28.0"
    }
  }
}
