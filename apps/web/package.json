{
  "name": "@do-epub-studio/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "ANALYZE=true tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@do-epub-studio/reader-core": "workspace:*",
    "@do-epub-studio/shared": "workspace:*",
    "@do-epub-studio/ui": "workspace:*",
    "epubjs": "^0.3.93",
    "framer-motion": "^12",
    "idb": "^8.0.3",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^7",
    "uuid": "^14.0.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "zod": "^3.25.76",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "4.1.4",
    "autoprefixer": "^10",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "8.0.9",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.1.4"
