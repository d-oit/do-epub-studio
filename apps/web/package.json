{
  "name": "@do-epub-studio/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "ANALYZE=true tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test:bundle": "node ../../scripts/check-bundle-size.mjs",
    "test:unit": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test": "echo \"Use test:unit or pnpm test:e2e from root\"",
    "test:e2e": "echo \"Run pnpm test:e2e from root\""
  },
  "dependencies": {
    "@do-epub-studio/reader-core": "workspace:*",
    "@do-epub-studio/shared": "workspace:*",
    "@do-epub-studio/ui": "workspace:*",
    "@intity/epub-js": "^0.3.96",
    "framer-motion": "^12",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "uuid": "^14.0.0",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-range-requests": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "fake-indexeddb": "^6.2.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.1.7"
  }
}
